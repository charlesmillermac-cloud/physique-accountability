generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum GoalType {
  CUT
  GAIN
  RECOMP
  CONTEST_PREP
}

enum MuscleGroup {
  CHEST
  BACK
  DELTS
  ARMS
  QUADS
  HAMSTRINGS
  GLUTES
  CALVES
  ABS
}

enum EquipmentAccess {
  FULL_GYM
  BARBELL_RACK
  DUMBBELLS
  MACHINES
  CABLES
  RESISTANCE_BANDS
  CARDIO_MACHINES
  BODYWEIGHT_ONLY
}

enum CheckInCompletionStatus {
  PENDING
  PARTIAL
  COMPLETED
  MISSED
}

enum ScoreStatus {
  COMPLETE
  DEGRADED
  INCOMPLETE
}

enum ScheduledPromptType {
  DAILY_CHECK_IN
  WEEKLY_CHECK_IN
  GENERAL_ACCOUNTABILITY
}

enum ScheduledPromptStatus {
  SCHEDULED
  SENT
  PARTIAL
  COMPLETED
  OVERDUE
  ESCALATED
  CLOSED
}

enum PromptAttemptType {
  INITIAL_SEND
  REMINDER
  ESCALATION
  MANUAL_FOLLOW_UP
}

enum PromptAttemptStatus {
  QUEUED
  SENT
  FAILED
  ACKNOWLEDGED
  NO_RESPONSE
}

enum MessageChannel {
  IN_APP
  EMAIL
  SMS
  SYSTEM
}

enum AccountabilityFlagType {
  REPEATED_MISSED_WEIGH_INS
  MISSED_EVENING_CLOSEOUTS
  LOW_REPORTING_CONSISTENCY
  WEEKEND_ADHERENCE_ISSUES
  INCOMPLETE_CHECK_IN_PATTERN
  OTHER
}

enum FlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AccountabilityFlagStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum InterventionCategory {
  REMINDER_ADJUSTMENT
  REPORTING_RESET
  COMPLIANCE_CORRECTION
  COACH_REVIEW
  PLAN_ADJUSTMENT
  OTHER
}

enum InterventionSource {
  SYSTEM
  AI
  COACH
}

enum InterventionStatus {
  RECOMMENDED
  ACCEPTED
  ACTIVE
  RESOLVED
  DISMISSED
}

enum MessageHistoryType {
  ACCOUNTABILITY_PROMPT
  PROMPT_REMINDER
  PROMPT_ESCALATION
  AI_REVIEW_SUMMARY
  INTERVENTION_RECOMMENDATION
}

enum MessageHistoryStatus {
  GENERATED
  SENT
  FAILED
  LOGGED
}

enum MessageAuthor {
  SYSTEM
  AI
  COACH
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  firstName      String
  lastName       String
  timezone       String    @default("America/Denver")
  sex            Sex?
  age            Int?
  heightCm       Decimal?  @db.Decimal(5, 2)
  currentBodyweight Decimal? @db.Decimal(5, 2)
  estimatedBodyFatPercent Decimal? @db.Decimal(5, 2)
  trainingAgeYears Decimal? @db.Decimal(4, 2)
  status         UserStatus @default(ACTIVE)
  onboardingCompletedAt DateTime?
  activeGoalId   String?   @unique
  activeGoal     Goal?     @relation("ActiveGoal", fields: [activeGoalId, id], references: [id, userId])
  goals          Goal[]    @relation("UserGoals")
  dailyCheckIns  DailyCheckIn[]
  weeklyCheckIns WeeklyCheckIn[]
  complianceScores ComplianceScore[]
  reportingScores ReportingScore[]
  scheduledPrompts ScheduledPrompt[]
  accountabilityFlags AccountabilityFlag[]
  interventions  Intervention[]
  messageHistory MessageHistory[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([activeGoalId, id])
  @@index([status])
  @@index([onboardingCompletedAt])
}

model Goal {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation("UserGoals", fields: [userId], references: [id], onDelete: Cascade)
  activeForUser       User?     @relation("ActiveGoal")
  title               String
  description         String?
  status              GoalStatus @default(ACTIVE)
  goalType            GoalType
  priorityMuscleGroups MuscleGroup[] @default([])
  scheduleConstraints String?
  equipmentAccess     EquipmentAccess[] @default([])
  calorieTarget       Int?
  proteinTargetGrams  Int?
  carbsTargetGrams    Int?
  fatsTargetGrams     Int?
  stepTarget          Int?
  cardioTargetMinutes Int?
  startDate           DateTime  @db.Date
  targetEndDate       DateTime? @db.Date
  completedAt         DateTime?
  archivedAt          DateTime?
  dailyCheckIns       DailyCheckIn[]
  weeklyCheckIns      WeeklyCheckIn[]
  complianceScores    ComplianceScore[]
  reportingScores     ReportingScore[]
  scheduledPrompts    ScheduledPrompt[]
  accountabilityFlags AccountabilityFlag[]
  interventions       Intervention[]
  messageHistory      MessageHistory[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([id, userId])
  @@index([userId, status])
  @@index([userId, startDate])
  @@index([goalType, status])
}

model DailyCheckIn {
  id               String                  @id @default(cuid())
  userId           String
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId           String?
  goal             Goal?                   @relation(fields: [goalId], references: [id], onDelete: SetNull)
  date             DateTime                @db.Date
  morningWeight    Decimal?                @db.Decimal(5, 2)
  sleepHours       Decimal?                @db.Decimal(4, 2)
  trainingCompleted Boolean?
  cardioCompleted  Boolean?
  mealsOnPlan      Int?                    @db.SmallInt
  energy           Int?                    @db.SmallInt
  stress           Int?                    @db.SmallInt
  digestion        Int?                    @db.SmallInt
  libido           Int?                    @db.SmallInt
  notes            String?
  missingFields    String[]                @default([])
  completionStatus CheckInCompletionStatus @default(PENDING)
  submittedAt      DateTime?
  scheduledPrompts ScheduledPrompt[]       @relation("DailyCheckInPrompts")
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
  @@index([goalId, date])
  @@index([completionStatus, date])
}

model WeeklyCheckIn {
  id                            String                  @id @default(cuid())
  userId                        String
  user                          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId                        String?
  goal                          Goal?                   @relation(fields: [goalId], references: [id], onDelete: SetNull)
  weekStartDate                 DateTime                @db.Date
  averageBodyweight             Decimal?                @db.Decimal(5, 2)
  waistMeasurement              Decimal?                @db.Decimal(5, 2)
  frontPhotoUrl                 String?
  sidePhotoUrl                  String?
  backPhotoUrl                  String?
  trainingCompliancePercentage  Decimal?                @db.Decimal(5, 2)
  nutritionCompliancePercentage Decimal?                @db.Decimal(5, 2)
  subjectiveLook                String?
  recoveryState                 String?
  notes                         String?
  missingFields                 String[]                @default([])
  completionStatus              CheckInCompletionStatus @default(PENDING)
  submittedAt                   DateTime?
  scheduledPrompts              ScheduledPrompt[]       @relation("WeeklyCheckInPrompts")
  messageHistory                MessageHistory[]
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt

  @@unique([userId, weekStartDate])
  @@index([userId, weekStartDate])
  @@index([goalId, weekStartDate])
  @@index([completionStatus, weekStartDate])
}

model ComplianceScore {
  id                 String      @id @default(cuid())
  userId             String
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId             String?
  goal               Goal?       @relation(fields: [goalId], references: [id], onDelete: SetNull)
  windowStartDate    DateTime    @db.Date
  windowEndDate      DateTime    @db.Date
  score              Decimal?    @db.Decimal(5, 2)
  confidence         Decimal?    @db.Decimal(5, 2)
  status             ScoreStatus @default(INCOMPLETE)
  formulaVersion     String
  componentBreakdown Json?
  notes              String?
  calculatedAt       DateTime    @default(now())

  @@unique([userId, goalId, windowStartDate, windowEndDate, formulaVersion])
  @@index([userId, windowStartDate])
  @@index([goalId, windowStartDate])
  @@index([status, calculatedAt])
  @@index([calculatedAt])
}

model ReportingScore {
  id                 String      @id @default(cuid())
  userId             String
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId             String?
  goal               Goal?       @relation(fields: [goalId], references: [id], onDelete: SetNull)
  windowStartDate    DateTime    @db.Date
  windowEndDate      DateTime    @db.Date
  score              Decimal?    @db.Decimal(5, 2)
  confidence         Decimal?    @db.Decimal(5, 2)
  status             ScoreStatus @default(INCOMPLETE)
  formulaVersion     String
  componentBreakdown Json?
  notes              String?
  calculatedAt       DateTime    @default(now())

  @@unique([userId, goalId, windowStartDate, windowEndDate, formulaVersion])
  @@index([userId, windowStartDate])
  @@index([goalId, windowStartDate])
  @@index([status, calculatedAt])
  @@index([calculatedAt])
}

model ScheduledPrompt {
  id                     String                @id @default(cuid())
  userId                 String
  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId                 String?
  goal                   Goal?                 @relation(fields: [goalId], references: [id], onDelete: SetNull)
  dailyCheckInId         String?
  dailyCheckIn           DailyCheckIn?         @relation("DailyCheckInPrompts", fields: [dailyCheckInId], references: [id], onDelete: SetNull)
  weeklyCheckInId        String?
  weeklyCheckIn          WeeklyCheckIn?        @relation("WeeklyCheckInPrompts", fields: [weeklyCheckInId], references: [id], onDelete: SetNull)
  promptType             ScheduledPromptType
  status                 ScheduledPromptStatus @default(SCHEDULED)
  channel                MessageChannel        @default(IN_APP)
  scheduledFor           DateTime
  dueAt                  DateTime?
  sentAt                 DateTime?
  lastAttemptAt          DateTime?
  completedAt            DateTime?
  escalatedAt            DateTime?
  closedAt               DateTime?
  currentEscalationLevel Int                   @default(0)
  context                Json?
  promptAttempts         PromptAttempt[]
  messageHistory         MessageHistory[]
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([userId, status, scheduledFor])
  @@index([userId, dueAt])
  @@index([goalId, status])
  @@index([dailyCheckInId])
  @@index([weeklyCheckInId])
}

model PromptAttempt {
  id               String              @id @default(cuid())
  scheduledPromptId String
  scheduledPrompt  ScheduledPrompt     @relation(fields: [scheduledPromptId], references: [id], onDelete: Cascade)
  attemptNumber    Int
  attemptType      PromptAttemptType
  status           PromptAttemptStatus @default(QUEUED)
  channel          MessageChannel      @default(IN_APP)
  escalationLevel  Int                 @default(0)
  attemptedAt      DateTime?
  respondedAt      DateTime?
  notes            String?
  messageHistory   MessageHistory[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([scheduledPromptId, attemptNumber])
  @@index([scheduledPromptId, attemptType])
  @@index([status, attemptedAt])
}

model AccountabilityFlag {
  id              String                    @id @default(cuid())
  userId          String
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId          String?
  goal            Goal?                     @relation(fields: [goalId], references: [id], onDelete: SetNull)
  flagType        AccountabilityFlagType
  severity        FlagSeverity              @default(MEDIUM)
  status          AccountabilityFlagStatus  @default(OPEN)
  title           String
  description     String?
  firstObservedAt DateTime                  @default(now())
  lastObservedAt  DateTime                  @default(now())
  detectedAt      DateTime                  @default(now())
  occurrenceCount Int                       @default(1)
  evidence        Json?
  resolvedAt      DateTime?
  interventions   Intervention[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([userId, status, detectedAt])
  @@index([userId, flagType, status])
  @@index([goalId, status])
}

model Intervention {
  id                String               @id @default(cuid())
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId            String?
  goal              Goal?                @relation(fields: [goalId], references: [id], onDelete: SetNull)
  accountabilityFlagId String?
  accountabilityFlag AccountabilityFlag? @relation(fields: [accountabilityFlagId], references: [id], onDelete: SetNull)
  category          InterventionCategory
  source            InterventionSource
  status            InterventionStatus   @default(RECOMMENDED)
  title             String
  recommendedAction String
  rationale         String?
  recommendedAt     DateTime             @default(now())
  acknowledgedAt    DateTime?
  resolvedAt        DateTime?
  messageHistory    MessageHistory[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([userId, status, recommendedAt])
  @@index([goalId, status])
  @@index([accountabilityFlagId])
}

model MessageHistory {
  id                String               @id @default(cuid())
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId            String?
  goal              Goal?                @relation(fields: [goalId], references: [id], onDelete: SetNull)
  scheduledPromptId String?
  scheduledPrompt   ScheduledPrompt?     @relation(fields: [scheduledPromptId], references: [id], onDelete: SetNull)
  promptAttemptId   String?
  promptAttempt     PromptAttempt?       @relation(fields: [promptAttemptId], references: [id], onDelete: SetNull)
  weeklyCheckInId   String?
  weeklyCheckIn     WeeklyCheckIn?       @relation(fields: [weeklyCheckInId], references: [id], onDelete: SetNull)
  interventionId    String?
  intervention      Intervention?        @relation(fields: [interventionId], references: [id], onDelete: SetNull)
  messageType       MessageHistoryType
  status            MessageHistoryStatus @default(LOGGED)
  channel           MessageChannel       @default(SYSTEM)
  author            MessageAuthor
  subject           String?
  content           String
  metadata          Json?
  sentAt            DateTime?
  createdAt         DateTime             @default(now())

  @@index([userId, createdAt])
  @@index([messageType, createdAt])
  @@index([scheduledPromptId, createdAt])
  @@index([weeklyCheckInId, createdAt])
  @@index([interventionId, createdAt])
}
